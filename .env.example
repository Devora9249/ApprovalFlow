
i API key used by DecisionService's GeminiProvider (Layer 2).
# Not required when LLM_PROVIDER=stub (e.g. in CI). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which ILlmProvider implementation DecisionService wires up. "gemini" calls the real
# Gemini API; "stub" uses StubLlmProvider (deterministic, no network call — used in CI).
LLM_PROVIDER=gemini

# Gemini model name passed to the generateContent API when LLM_PROVIDER=gemini.
LLM_MODEL=gemini-2.5-flash

# Layer 1 / Layer 3 policy thresholds (never hardcoded — see CLAUDE.md). Invoices above
# this total always escalate to a human, regardless of what the AI agent recommends.
AUTONOMY_CEILING=500

# Layer 3 final gate: the agent's recommendation is only trusted at or above this
# confidence; anything lower escalates to a human even if the agent says auto_approve.
AUTONOMY_CONFIDENCE=0.80

# Layer 1 category white list — comma-separated, no spaces around commas required.
# Hot-configurable: change this and restart decision-service, no rebuild needed.
WHITELIST_CATEGORIES=office_supplies,business_meals,transportation,software,hardware

# Layer 1 known-vendor list — comma-separated. Hot-configurable: change this and
# restart decision-service, no rebuild needed.
KNOWN_VENDORS=Staples,Amazon Business,Uber,Bistro 19,Microsoft,Dell Technologies,Delta Airlines

# Test/demo escape hatch for PaymentService: when true, every mock payment fails,
# exercising the saga's compensation path (reservation release + payment.failed).
# INV-1012 always forces a failure regardless of this flag (see PaymentProcessor.cs).
FORCE_PAYMENT_FAIL=false

# Symmetric signing key Gateway uses to issue and validate JWTs (HMAC-SHA256).
# Never hardcoded — generate a long random value for anything beyond local dev.
# Must be at least 32 characters; Gateway refuses to start otherwise (JwtSecretValidator).
JWT_SECRET=dev_only_change_me_to_a_long_random_secret
